{
  "name": "@sourdough/frontend",
  "version": "1.0.0",
  "description": "CS4530 Template",
  "type": "module",
  "scripts": {
    "check": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --ignore-path ../.gitignore --check .",
    "prettier:fix": "prettier --ignore-path ../.gitignore --write .",
    "test": "playwright test",
    "dev": "vite",
